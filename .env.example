# =============================================================================
# Arxiv-Agentic_RAG Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub - it's in .gitignore
# This .env.example is safe to share (contains only placeholder values)
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
SERVICE_NAME=rag-api

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=vaibhav
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DATABASE_URL=postgresql+psycopg2://vaibhav:your_secure_password_here@postgres:5432/rag_project_db

# Optional: For local development outside Docker
# POSTGRES_DATABASE_URL=postgresql+psycopg2://vaibhav:your_secure_password_here@localhost:5432/rag_project_db

# =============================================================================
# arXiv API Settings
# =============================================================================
ARXIV__BASE_URL=https://export.arxiv.org/api/query
ARXIV__PDF_CACHE_DIR=./data/arxiv_pdfs
ARXIV__RATE_LIMIT_DELAY=3.0
ARXIV__TIMEOUT_SECONDS=30
ARXIV__MAX_RESULTS=15
ARXIV__SEARCH_CATEGORY=cs.AI
ARXIV__DOWNLOAD_MAX_RETRIES=3
ARXIV__DOWNLOAD_RETRY_DELAY_BASE=5.0
ARXIV__MAX_CONCURRENT_DOWNLOADS=5
ARXIV__MAX_CONCURRENT_PARSING=1

# =============================================================================
# OpenSearch Settings
# =============================================================================
OPENSEARCH__HOST=http://opensearch:9200
OPENSEARCH__INDEX_NAME=arxiv-papers
OPENSEARCH__CHUNK_INDEX_SUFFIX=chunks
OPENSEARCH__MAX_TEXT_SIZE=1000000
OPENSEARCH__VECTOR_DIMENSION=1024
OPENSEARCH__VECTOR_SPACE_TYPE=cosinesimil
OPENSEARCH__RRF_PIPELINE_NAME=hybrid-rrf-pipeline
OPENSEARCH__HYBRID_SEARCH_SIZE_MULTIPLIER=2

# =============================================================================
# Ollama (Local LLM)
# =============================================================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

# =============================================================================
# Jina AI Embeddings API
# Get your free API key from: https://jina.ai/embeddings/
# =============================================================================
JINA_API_KEY=your_jina_api_key_here

# =============================================================================
# PDF Parser Settings
# =============================================================================
PDF_PARSER__MAX_PAGES=30
PDF_PARSER__MAX_FILE_SIZE_MB=20
PDF_PARSER__DO_OCR=false
PDF_PARSER__DO_TABLE_STRUCTURE=true

# =============================================================================
# Text Chunking Settings
# =============================================================================
CHUNKING__CHUNK_SIZE=600
CHUNKING__OVERLAP_SIZE=100
CHUNKING__MIN_CHUNK_SIZE=100
CHUNKING__SECTION_BASED=true

# =============================================================================
# Redis Cache Settings
# =============================================================================
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__DB=0
REDIS__DECODE_RESPONSES=true
REDIS__SOCKET_TIMEOUT=30
REDIS__SOCKET_CONNECT_TIMEOUT=30
REDIS__TTL_HOURS=6

# =============================================================================
# Telegram Bot (Optional)
# Get bot token from @BotFather on Telegram
# =============================================================================
TELEGRAM__BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM__ENABLED=false

# =============================================================================
# Langfuse Observability (Optional but recommended)
# Sign up at: https://langfuse.com
# =============================================================================
LANGFUSE__PUBLIC_KEY=your_langfuse_public_key
LANGFUSE__SECRET_KEY=your_langfuse_secret_key
LANGFUSE__HOST=http://langfuse-web:3000
LANGFUSE__ENABLED=true
LANGFUSE__FLUSH_AT=15
LANGFUSE__FLUSH_INTERVAL=1.0
LANGFUSE__MAX_RETRIES=3
LANGFUSE__TIMEOUT=30
LANGFUSE__DEBUG=false

# Langfuse Internal Services (Docker Compose uses these)
LANGFUSE_SALT=generate_a_random_salt_string_here
LANGFUSE_NEXTAUTH_SECRET=generate_a_random_secret_here
ENCRYPTION_KEY=generate_a_32_char_encryption_key
CLICKHOUSE_PASSWORD=changeme
LANGFUSE_DB_PASSWORD=changeme
LANGFUSE_REDIS_PASSWORD=changeme
LANGFUSE_MINIO_ACCESS_KEY=minio
LANGFUSE_MINIO_SECRET_KEY=minio123
MINIO_ROOT_USER=langfuse_minio
MINIO_ROOT_PASSWORD=langfuse_minio_secret
LANGFUSE_EMAIL=admin@example.com
LANGFUSE_USER=Admin
LANGFUSE_PASSWORD=admin123

# =============================================================================
# AWS S3 (Optional - for cloud storage)
# =============================================================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# =============================================================================
# OpenAI / Anthropic (Optional - if using cloud LLMs)
# =============================================================================
# OPENAI_API_KEY=sk-your_openai_key_here
# ANTHROPIC_API_KEY=sk-your_anthropic_key_here

# =============================================================================
# Development / Testing
# =============================================================================
PYTEST_CURRENT_TEST=false
TESTING=false

# =============================================================================
# Security Notes:
# =============================================================================
# 1. NEVER commit this file with real values to GitHub
# 2. Keep your .env file private and secure
# 3. Rotate API keys regularly
# 4. Use strong passwords for database
# 5. For production, use a secrets manager like AWS Secrets Manager or HashiCorp Vault
# =============================================================================
